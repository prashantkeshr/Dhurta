<?xml version="1.0" encoding="utf-8"?>
<!-- Dhurta mobile browser chrome — cyberpunk dark, thumb-first:
     compact top URL pill · WebView · floating bottom dock with a raised center
     Dhurta Hub · slide-out command drawer. -->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- ── Main content ── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/obsidian">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Compact URL pill -->
            <LinearLayout
                android:id="@+id/urlPill"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_margin="10dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="7dp"
                android:background="@drawable/pill_bg">

                <TextView
                    android:id="@+id/protectionBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EXPOSED"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="@color/exposed_red"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/urlBar"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:hint="@string/url_hint"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:singleLine="true"
                    android:imeOptions="actionGo"
                    android:inputType="textUri"
                    android:background="@android:color/transparent"
                    android:importantForAutofill="no" />

                <ImageButton
                    android:id="@+id/reloadBtn"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@android:drawable/ic_popup_sync"
                    android:background="?android:selectableItemBackgroundBorderless"
                    android:contentDescription="Reload"
                    app:tint="@color/neon_blue" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/neon_blue"
                android:visibility="gone" />

            <WebView
                android:id="@+id/webView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- spacer so page content isn't hidden behind the floating dock -->
            <View android:layout_width="match_parent" android:layout_height="74dp" />
        </LinearLayout>

        <!-- Floating bottom dock -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="14dp"
            android:layout_marginBottom="16dp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:background="@drawable/dock_bg"
            android:elevation="12dp"
            android:clipChildren="false">

            <ImageButton
                android:id="@+id/backBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_media_previous"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                app:tint="@color/text" />

            <ImageButton
                android:id="@+id/forwardBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_media_next"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="Forward"
                app:tint="@color/text" />

            <!-- Raised center Dhurta Hub -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clipChildren="false">

                <View
                    android:id="@+id/hubRing"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="-18dp"
                    android:background="@drawable/hub_ring" />

                <ImageView
                    android:id="@+id/hubBtn"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="-18dp"
                    android:padding="11dp"
                    android:background="@drawable/hub_bg"
                    android:src="@mipmap/ic_launcher"
                    android:elevation="8dp"
                    android:contentDescription="Dhurta Hub" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1">

                <ImageButton
                    android:id="@+id/tabsBtn"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_dialog_dialer"
                    android:background="?android:selectableItemBackgroundBorderless"
                    android:contentDescription="Tabs"
                    app:tint="@color/text" />

                <TextView
                    android:id="@+id/tabCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="8dp"
                    android:text="1"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:textColor="@color/neon_blue"
                    android:paddingHorizontal="4dp"
                    android:background="@drawable/tabcount_bg" />
            </FrameLayout>

            <ImageButton
                android:id="@+id/homeBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_menu_view"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="Home"
                app:tint="@color/text" />
        </LinearLayout>
    </FrameLayout>

    <!-- ── Command drawer ── -->
    <LinearLayout
        android:layout_width="290dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@color/obsidian_elev"
        android:fitsSystemWindows="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="28dp"
            android:background="@color/obsidian">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="Dhurta" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DHURTA"
                android:textColor="@color/saffron"
                android:textSize="16sp"
                android:letterSpacing="0.36"
                android:fontFamily="monospace"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sovereign · Privacy-Native"
                android:textColor="@color/text_muted"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" />

        <TextView android:id="@+id/navOmni" style="@style/DrawerRow" android:text="🔱   Omni Dashboard" android:textColor="@color/neon_blue" />
        <TextView android:id="@+id/navNewTab" style="@style/DrawerRow" android:text="🏠   New Tab" />
        <TextView android:id="@+id/navGhost" style="@style/DrawerRow" android:text="👻   Ghost Mode" />
        <TextView android:id="@+id/navBookmarks" style="@style/DrawerRow" android:text="🔖   Bookmarks" />
        <TextView android:id="@+id/navHistory" style="@style/DrawerRow" android:text="🕑   History" />
        <TextView android:id="@+id/navDownloads" style="@style/DrawerRow" android:text="⬇   Downloads" />
        <TextView android:id="@+id/navDevtools" style="@style/DrawerRow" android:text="⚙   Developer Mode" />
        <TextView android:id="@+id/navSettings" style="@style/DrawerRow" android:text="⚙   Settings" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" android:layout_marginVertical="6dp" />

        <TextView android:id="@+id/navAbout" style="@style/DrawerRow" android:text="ℹ   About Dhurta" />
    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>
