<?xml version="1.0" encoding="utf-8"?>
<!-- Dhurta mobile browser chrome — Chrome/Opera-grade layout in the cyberpunk skin:
     top URL pill · find-in-page bar · multi-tab WebView container · floating
     bottom dock (back / forward / Hub / tabs / menu) · slide-up menu sheet ·
     slide-out command drawer. -->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- ── Main content ── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/obsidian">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Compact URL pill -->
            <LinearLayout
                android:id="@+id/urlPill"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="6dp"
                android:paddingStart="12dp"
                android:paddingEnd="4dp"
                android:background="@drawable/pill_bg">

                <TextView
                    android:id="@+id/protectionBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EXPOSED"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="@color/exposed_red"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/urlBar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="@string/url_hint"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:singleLine="true"
                    android:imeOptions="actionGo"
                    android:inputType="textUri"
                    android:background="@android:color/transparent"
                    android:importantForAutofill="no" />

                <ImageButton
                    android:id="@+id/reloadBtn"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_popup_sync"
                    android:background="?android:selectableItemBackgroundBorderless"
                    android:contentDescription="Reload"
                    app:tint="@color/neon_blue" />
            </LinearLayout>

            <!-- Find-in-page bar (hidden until menu → Find in page) -->
            <LinearLayout
                android:id="@+id/findBar"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="10dp"
                android:layout_marginBottom="6dp"
                android:paddingStart="12dp"
                android:paddingEnd="4dp"
                android:background="@drawable/pill_bg"
                android:visibility="gone">

                <EditText
                    android:id="@+id/findInput"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Find in page"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:singleLine="true"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:background="@android:color/transparent"
                    android:importantForAutofill="no" />

                <TextView
                    android:id="@+id/findCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/0"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_muted"
                    android:layout_marginEnd="6dp" />

                <ImageButton
                    android:id="@+id/findPrev"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@android:drawable/arrow_up_float"
                    android:background="?android:selectableItemBackgroundBorderless"
                    android:contentDescription="Previous match"
                    app:tint="@color/text" />

                <ImageButton
                    android:id="@+id/findNext"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@android:drawable/arrow_down_float"
                    android:background="?android:selectableItemBackgroundBorderless"
                    android:contentDescription="Next match"
                    app:tint="@color/text" />

                <ImageButton
                    android:id="@+id/findClose"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:background="?android:selectableItemBackgroundBorderless"
                    android:contentDescription="Close find"
                    app:tint="@color/text" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/neon_blue"
                android:visibility="gone" />

            <!-- Tabs live here: the layout WebView is tab #1, more are added in code -->
            <FrameLayout
                android:id="@+id/webContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <WebView
                    android:id="@+id/webView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </FrameLayout>

            <!-- spacer so page content isn't hidden behind the floating dock -->
            <View
                android:id="@+id/dockSpacer"
                android:layout_width="match_parent"
                android:layout_height="72dp" />
        </LinearLayout>

        <!-- Floating bottom dock — 5 equal slots, Opera-style with raised center Hub -->
        <LinearLayout
            android:id="@+id/dock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="14dp"
            android:layout_marginBottom="14dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="5dp"
            android:background="@drawable/dock_bg"
            android:elevation="12dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <ImageButton
                android:id="@+id/backBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_media_previous"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                app:tint="@color/text" />

            <ImageButton
                android:id="@+id/forwardBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_media_next"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="Forward"
                app:tint="@color/text" />

            <!-- Raised center Dhurta Hub -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:clipChildren="false"
                android:clipToPadding="false">

                <View
                    android:id="@+id/hubRing"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center_horizontal"
                    android:translationY="-14dp"
                    android:background="@drawable/hub_ring" />

                <ImageView
                    android:id="@+id/hubBtn"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center_horizontal"
                    android:translationY="-11dp"
                    android:padding="11dp"
                    android:background="@drawable/hub_bg"
                    android:src="@mipmap/ic_launcher"
                    android:elevation="8dp"
                    android:contentDescription="Dhurta Hub" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1">

                <ImageButton
                    android:id="@+id/tabsBtn"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_dialog_dialer"
                    android:background="?android:selectableItemBackgroundBorderless"
                    android:contentDescription="Tabs"
                    app:tint="@color/text" />

                <TextView
                    android:id="@+id/tabCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="8dp"
                    android:text="1"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:textColor="@color/neon_blue"
                    android:paddingHorizontal="4dp"
                    android:background="@drawable/tabcount_bg" />
            </FrameLayout>

            <ImageButton
                android:id="@+id/menuBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="Menu"
                app:tint="@color/text" />
        </LinearLayout>

        <!-- ── Slide-up browser menu (Chrome ⋮ equivalent) ── -->
        <FrameLayout
            android:id="@+id/menuOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#B3000000"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <androidx.core.widget.NestedScrollView
                android:id="@+id/menuSheet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:background="@drawable/dock_bg"
                android:layout_margin="10dp"
                android:elevation="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <!-- Quick action row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="8dp"
                        android:paddingBottom="4dp">

                        <TextView android:id="@+id/mHome" style="@style/MenuQuick" android:text="🏠" />
                        <TextView android:id="@+id/mAddBookmark" style="@style/MenuQuick" android:text="⭐" />
                        <TextView android:id="@+id/mShare" style="@style/MenuQuick" android:text="📤" />
                        <TextView android:id="@+id/mOmni" style="@style/MenuQuick" android:text="🔱" />
                        <TextView android:id="@+id/mNewTab" style="@style/MenuQuick" android:text="➕" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" />

                    <!-- Two-column feature grid -->
                    <LinearLayout style="@style/MenuRowPair">
                        <TextView android:id="@+id/mFind" style="@style/MenuItem" android:text="🔍  Find in page" />
                        <TextView android:id="@+id/mDesktop" style="@style/MenuItem" android:text="🖥  Desktop site" />
                    </LinearLayout>
                    <LinearLayout style="@style/MenuRowPair">
                        <TextView android:id="@+id/mFullscreen" style="@style/MenuItem" android:text="⛶  Fullscreen" />
                        <TextView android:id="@+id/mInspect" style="@style/MenuItem" android:text="🧪  Inspect element" />
                    </LinearLayout>
                    <LinearLayout style="@style/MenuRowPair">
                        <TextView android:id="@+id/mBookmarks" style="@style/MenuItem" android:text="🔖  Bookmarks" />
                        <TextView android:id="@+id/mHistory" style="@style/MenuItem" android:text="🕑  History" />
                    </LinearLayout>
                    <LinearLayout style="@style/MenuRowPair">
                        <TextView android:id="@+id/mDownloads" style="@style/MenuItem" android:text="⬇  Downloads" />
                        <TextView android:id="@+id/mAutoClean" style="@style/MenuItem" android:text="🧹  Auto-Clean" />
                    </LinearLayout>
                    <LinearLayout style="@style/MenuRowPair">
                        <TextView android:id="@+id/mSettings" style="@style/MenuItem" android:text="⚙  Settings" />
                        <TextView android:id="@+id/mExit" style="@style/MenuItem" android:text="✕  Close menu" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </FrameLayout>
    </FrameLayout>

    <!-- ── Command drawer (desktop feature parity) ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="292dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/obsidian_elev"
        android:fitsSystemWindows="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header with mode logos -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="26dp"
                android:background="@color/obsidian">

                <ImageView
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:src="@mipmap/ic_launcher"
                    android:contentDescription="Dhurta" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DHURTA"
                    android:textColor="@color/saffron"
                    android:textSize="16sp"
                    android:letterSpacing="0.36"
                    android:fontFamily="monospace"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sovereign · Privacy-Native"
                    android:textColor="@color/text_muted"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" />

            <TextView android:id="@+id/navOmni" style="@style/DrawerRow" android:text="🔱   Omni Dashboard" android:textColor="@color/neon_blue" />
            <TextView android:id="@+id/navNewTab" style="@style/DrawerRow" android:text="🏠   New Tab" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" android:layout_marginVertical="4dp" />
            <TextView style="@style/DrawerHeading" android:text="PROTECTION" />

            <!-- Real desktop mode logos via drawableStart -->
            <TextView android:id="@+id/navGhost" style="@style/DrawerRow"
                android:drawableStart="@drawable/ic_ghost" android:drawablePadding="14dp" android:text="Ghost Mode — Tor" />
            <TextView android:id="@+id/navChakra" style="@style/DrawerRow"
                android:drawableStart="@drawable/ic_chakra" android:drawablePadding="14dp" android:text="Chakra Shield — VPN" />
            <TextView android:id="@+id/navSecurity" style="@style/DrawerRow" android:text="🛡   Security Center" />
            <TextView android:id="@+id/navNetwork" style="@style/DrawerRow" android:text="📡   Network Monitor" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" android:layout_marginVertical="4dp" />
            <TextView style="@style/DrawerHeading" android:text="LIBRARY" />

            <TextView android:id="@+id/navBookmarks" style="@style/DrawerRow" android:text="🔖   Bookmarks" />
            <TextView android:id="@+id/navHistory" style="@style/DrawerRow" android:text="🕑   History" />
            <TextView android:id="@+id/navDownloads" style="@style/DrawerRow" android:text="⬇   Downloads" />
            <TextView android:id="@+id/navConnect" style="@style/DrawerRow" android:text="🔗   Dhurta Connect" />
            <TextView android:id="@+id/navExtensions" style="@style/DrawerRow" android:text="🧩   Extensions" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" android:layout_marginVertical="4dp" />
            <TextView style="@style/DrawerHeading" android:text="SYSTEM" />

            <TextView android:id="@+id/navDevtools" style="@style/DrawerRow" android:text="🧪   Developer Mode" />
            <TextView android:id="@+id/navSettings" style="@style/DrawerRow" android:text="⚙   Settings" />
            <TextView android:id="@+id/navWipe" style="@style/DrawerRow" android:text="☢   Nuclear Wipe" android:textColor="@color/exposed_red" />
            <TextView android:id="@+id/navAbout" style="@style/DrawerRow" android:text="ℹ   About Dhurta" />

            <View android:layout_width="match_parent" android:layout_height="20dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.drawerlayout.widget.DrawerLayout>
