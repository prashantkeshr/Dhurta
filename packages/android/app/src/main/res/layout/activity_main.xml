<?xml version="1.0" encoding="utf-8"?>
<!-- Dhurta mobile browser chrome, matching the desktop's obsidian/saffron
     standard: top URL/search bar with PROTECTED/EXPOSED badge, WebView content,
     bottom nav, and a slide-out sidebar drawer with the feature rail. -->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- ── Main content ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/obsidian">

        <!-- Top URL / search bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="6dp"
            android:paddingVertical="6dp"
            android:background="@color/obsidian_elev">

            <ImageButton
                android:id="@+id/menuBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="Menu"
                app:tint="@color/saffron" />

            <TextView
                android:id="@+id/protectionBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXPOSED"
                android:textSize="8sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:textColor="@color/exposed_red"
                android:paddingHorizontal="4dp"
                android:layout_marginEnd="4dp" />

            <EditText
                android:id="@+id/urlBar"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:hint="@string/url_hint"
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:singleLine="true"
                android:imeOptions="actionGo"
                android:inputType="textUri"
                android:background="@color/surface"
                android:paddingHorizontal="12dp"
                android:importantForAutofill="no" />

            <ImageButton
                android:id="@+id/reloadBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_popup_sync"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="Reload"
                app:tint="@color/text_muted" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/saffron"
            android:visibility="gone" />

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Bottom nav -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@color/obsidian_elev"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/backBtn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:src="@android:drawable/ic_media_previous"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                app:tint="@color/text" />

            <ImageButton
                android:id="@+id/forwardBtn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:src="@android:drawable/ic_media_next"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="Forward"
                app:tint="@color/text" />

            <ImageButton
                android:id="@+id/homeBtn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:src="@android:drawable/ic_menu_view"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="Home"
                app:tint="@color/text" />

            <TextView
                android:id="@+id/ghostToggle"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="👻"
                android:textSize="20sp"
                android:gravity="center"
                android:alpha="0.5"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="Ghost Mode" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── Sidebar drawer ── -->
    <LinearLayout
        android:layout_width="286dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@color/obsidian_elev"
        android:fitsSystemWindows="true">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="26dp"
            android:background="@color/obsidian">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="Dhurta" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DHURTA"
                android:textColor="@color/saffron"
                android:textSize="15sp"
                android:letterSpacing="0.35"
                android:fontFamily="monospace"
                android:layout_marginTop="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sovereign · Privacy-Native"
                android:textColor="@color/text_muted"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" />

        <TextView android:id="@+id/navNewTab" style="@style/DrawerRow" android:text="🏠   New Tab" />
        <TextView android:id="@+id/navGhost" style="@style/DrawerRow" android:text="👻   Ghost Mode" />
        <TextView android:id="@+id/navBookmarks" style="@style/DrawerRow" android:text="🔖   Bookmarks" />
        <TextView android:id="@+id/navHistory" style="@style/DrawerRow" android:text="🕑   History" />
        <TextView android:id="@+id/navDownloads" style="@style/DrawerRow" android:text="⬇   Downloads" />
        <TextView android:id="@+id/navSecurity" style="@style/DrawerRow" android:text="🛡   Security" />
        <TextView android:id="@+id/navSettings" style="@style/DrawerRow" android:text="⚙   Settings" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" android:layout_marginVertical="6dp" />

        <TextView android:id="@+id/navAbout" style="@style/DrawerRow" android:text="ℹ   About Dhurta" />
    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>
