<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark, edge-to-edge browser chrome. Parent is a non-ActionBar AppCompat
         theme so MainActivity owns the entire surface (its own URL bar). -->
    <style name="Theme.Dhurta" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/saffron</item>
        <item name="colorPrimaryDark">@color/obsidian</item>
        <item name="colorAccent">@color/saffron</item>
        <item name="android:colorBackground">@color/obsidian</item>
        <item name="android:statusBarColor">@color/obsidian</item>
        <item name="android:navigationBarColor">@color/obsidian</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/obsidian</item>
    </style>

    <!-- Sidebar row: full-width tappable label in the brand's mono/obsidian look. -->
    <style name="DrawerRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">22dp</item>
        <item name="android:paddingVertical">14dp</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:background">?android:selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>
</resources>
